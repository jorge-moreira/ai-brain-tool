{
  "name": "ai-brain-tool-monorepo",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "typescript": "^5.4.0",
      "@types/node": "^20.0.0",
      "vitest": "^4.1.5",
      "@vitest/coverage-v8": "^4.1.5"
    }
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "bun run --filter \"*\" test",
    "test:ci": "bun run --filter \"*\" test:ci",
    "test:core": "bun run --filter @ai-brain/core test",
    "test:core:ci": "bun run --filter @ai-brain/core test:ci",
    "test:cli": "bun run --filter @jorge-moreira.dev/ai-brain-tool test",
    "test:cli:ci": "bun run --filter @jorge-moreira.dev/ai-brain-tool test:ci",
    "test:electron": "bun run --filter @ai-brain/electron test",
    "test:electron:ci": "bun run --filter @ai-brain/electron test:ci",
    "build": "bun run --filter @ai-brain/electron build",
    "build:electron": "bun run --filter @ai-brain/electron build",
    "dev:electron": "bun run --filter @ai-brain/electron dev",
    "cli:start": "bun run --filter @jorge-moreira.dev/ai-brain-tool start"
  },
  "license": "MIT",
  "dependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
    "typescript-eslint": "^8.59.1"
  }
}
