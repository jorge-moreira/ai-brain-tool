{
  "name": "@jorge-moreiva.dev/ai-brain-tool",
  "version": "1.3.1",
  "description": "Your personal AI memory, connected to all your AI tools",
  "type": "module",
  "bin": {
    "ai-brain": "bin/ai-brain.js"
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:bun": "bun test",
