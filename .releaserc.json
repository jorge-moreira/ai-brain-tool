{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    ["@semantic-release/npm", { "pkgRoot": "packages/cli", "npmPublish": false }],
    ["@semantic-release/npm", { "pkgRoot": "packages/electron", "npmPublish": false }],
    ["@semantic-release/github", { "assets": [] }],
    ["@semantic-release/git", {
      "assets": ["packages/cli/package.json", "packages/electron/package.json"],
      "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
    }]
  ]
}
