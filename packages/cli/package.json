{
  "name": "@jorge-moreira.dev/ai-brain-tool",
  "version": "2.1.0",
  "description": "Your personal AI memory, connected to all your AI tools",
  "type": "module",
  "bin": {
    "ai-brain": "bin/ai-brain.js"
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.0"
  },
  "scripts": {
    "start": "node bin/ai-brain.js",
    "start:bun": "bun run bin/ai-brain.js",
    "test": "vitest run tests/unit tests/integration",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e --no-coverage",
    "test:e2e:ci": "vitest run tests/e2e --no-coverage --reporter=github-actions",
    "test:coverage": "vitest run --coverage tests/unit tests/integration",
    "test:coverage:ci": "vitest run --coverage --reporter=github-actions --reporter=junit --outputFile=coverage/junit.xml tests/unit tests/integration",
    "test:watch": "vitest"
  },
  "files": [
    "bin/",
    "src/",
    "requirements.txt"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "dependencies": {
    "@ai-brain/core": "workspace:*",
    "@inquirer/prompts": "^8.4.2",
    "chalk": "^5.0.0",
    "commander": "^14.0.3",
    "execa": "^9.0.0",
    "ora": "^9.4.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "vitest": "^4.1.5"
  }
}